{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/components/**/*.tsx", "src/hooks/**/*.ts", "src/types.ts"],
  "exclude": ["src/**/*.test.*", "src/**/*.stories.*", "src/demo"]
}
